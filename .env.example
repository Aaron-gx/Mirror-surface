# 复制此文件为 .env 并填入配置

# AI API
ANTHROPIC_API_KEY=your_api_key_here
MIMO_API_KEY=your_mimo_api_key_here

# Flask session signing
SECRET_KEY=change-this-to-a-random-string

# 公网访问地址（SSO 回调用，部署时自动设置）
PUBLIC_URL=http://your-domain:port

# SSO 接入 funpromotion-web
FUNPROMOTION_SSO_SHARED_SECRET=your-shared-secret
FUNPROMOTION_SSO_URL=http://your-sso-server
